# AWS Core
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Amazon Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_GUARDRAIL_ID=your-guardrail-id
BEDROCK_GUARDRAIL_VERSION=DRAFT

# Amazon Bedrock Agent (Comment Shield)
BEDROCK_AGENT_ID=your-agent-id
BEDROCK_AGENT_ALIAS_ID=your-agent-alias-id

# Amazon OpenSearch Serverless
OPENSEARCH_ENDPOINT=https://your-collection-id.us-east-1.aoss.amazonaws.com
OPENSEARCH_INDEX=creator-reach-patterns

# Amazon S3
S3_BUCKET_NAME=inflomnia-resilience-engine

# Database
DATABASE_URL=sqlite:///./inflomnia_dev.db   # Change to postgresql://... for production

# Auth (AWS Cognito via Amplify)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=your-cognito-client-id

# App
APP_ENV=development
DEBUG=true
